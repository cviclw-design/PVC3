# .env – development settings

# Flask
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=1

# Secret key (change this; long random string in real use)
SECRET_KEY=change_this_to_a_long_random_string

# Database: pick ONE of these patterns depending on what you use

# 1) MySQL (your original setup looked like this)
DATABASE_URL=mysql+pymysql://root:your_mysql_password@localhost/pvc_db2

# 2) Or SQLite for quick local testing (comment MySQL, uncomment this)
# DATABASE_URL=sqlite:///pvc_dev.db